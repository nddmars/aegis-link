# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic API key — required by Aegis-Brain (brain/processor.py)
ANTHROPIC_API_KEY=sk-ant-...

# Absolute or relative path to the SQLite database file.
# Defaults to aegis_intel.db in the project root if not set.
AEGIS_DB_PATH=/home/user/aegis-link/aegis_intel.db

# ── aegis-vulnops: DefectDojo (OPTIONAL — omit to run in Excel-only mode) ────
DEFECTDOJO_URL=https://your-defectdojo-instance.example.com
DEFECTDOJO_API_TOKEN=your-defectdojo-api-token

# ── aegis-vulnops: Jira (OPTIONAL — tickets rendered locally if not set) ─────
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=your-email@example.com
JIRA_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=SEC

# ── aegis-vulnops: SSH Verification ──────────────────────────────────────────
SSH_KEY_PATH=/home/user/.ssh/id_rsa
SSH_USERNAME=ubuntu

# ── aegis-vulnops: Checkmarx (OPTIONAL) ──────────────────────────────────────
CHECKMARX_URL=https://your-checkmarx.example.com
CHECKMARX_TOKEN=your-checkmarx-token

# ── aegis-vulnops: Agent Polling (DefectDojo mode) ───────────────────────────
VULNOPS_POLL_INTERVAL_SECONDS=300

# ── aegis-vulnops: Excel source (used with --source excel) ───────────────────
VULNOPS_EXCEL_FILE=findings.xlsx
